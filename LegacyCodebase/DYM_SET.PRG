CLOSE ALL
CLEAR ALL
SELECT 0
USE YER ALIAS YER
set filter to trim(ACT_PAS) = "Y"
go top
if year(TO_DAT) = 2009
    SELECT 0
    USE DIR ALIAS DIR
    SET DATE BRITISH
	DELETE ALL FOR DIR_IDY = "DAY" AND DIR_DAT <= CTOD("31/03/2008")
	PACK
	SET FILTER TO DIR_IDY = "SYS" AND DIR_IDX = "AYR"
	GO TOP
	REPLACE DIR_MSG WITH "T"
else
	SELECT 0
	USE DIR ALIAS DIR
	SET DATE BRITISH
	SET FILTER TO DIR_IDY = "SYS" AND DIR_IDX = "AYR"
	GO TOP
	REPLACE DIR_MSG WITH space(10)
endif
close all
clear all
return
