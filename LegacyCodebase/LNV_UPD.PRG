CLOSE ALL
CLEAR ALL
SELECT 0
USE LNV ALIAS LNV
SELECT 0
USE BRD INDEX BRD ALIAS BRD
SET ORDER TO BAT_IDY
SELECT 0
USE PRD INDEX PRD ALIAS PRD
SET ORDER TO PRD_IDY
SELECT 0
USE SCH INDEX SCH ALIAS SCH
SET ORDER TO SCH_IDY
SELECT 0
USE PGR INDEX PGR ALIAS PGR
SET ORDER TO GRP_IDY
SELECT LNV
GO TOP
DO WHILE .NOT. EOF("LNV")
	SELECT SCH
	SEEK LNV.LEV_IDY
	IF FOUND()
		REPLACE LNV.MER_NUM WITH SCH.MER_NUM
	ENDIF
	SELECT BRD
	SEEK LNV.LEV_DES
	IF FOUND()
		SELECT PRD
		SEEK BRD.PRD_IDY
		IF FOUND()
			REPLACE LNV.PRD_PCK WITH PRD.PRD_PCK, LNV.SUB_UNT WITH PRD.SUB_UNT
		ENDIF
		SELECT PGR
		SEEK PRD.GRP_IDY
		IF FOUND()
			REPLACE LNV.GRP_CAT WITH PGR.GRP_CAT
		ENDIF
	ENDIF
	SELECT LNV
	SKIP 1
ENDDO
CLOSE ALL
