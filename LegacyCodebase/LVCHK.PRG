SET ESCAPE ON
CLOSE ALL
CLEAR ALL
SELECT 0
USE BRD INDEX BRD ALIAS BRD
SET ORDER TO 2
SELECT 0
USE LNV ALIAS LNV
SELECT LNV
set filter to INV_GRS > 0 AND LEN(TRIM(LEV_DES)) > 0 AND TXN_TYP = "FRE"
GO TOP
DO WHILE .NOT. EOF("LNV")
	SELECT BRD
	SEEK TRIM(LNV.LEV_DES)
	IF FOUND()
		REPLACE LNV.P_FRE_AMT WITH LNV.INV_GRS * BRD.U_PUR_LPP
		REPLACE LNV.S_FRE_AMT WITH LNV.INV_GRS * BRD.U_SAL_LPP
	ENDIF
	SELECT LNV
	SKIP 1
ENDDO
CLOSE ALL
RETURN
